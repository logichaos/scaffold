<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>{{TARGET_FRAMEWORK}}</TargetFramework>
    <RootNamespace>{{SOLUTION_NAME}}.Domain.Tests</RootNamespace>
    <AssemblyName>{{SOLUTION_NAME}}.Domain.Tests</AssemblyName>
    <IsPackable>false</IsPackable>
    <!-- Ignore exit code 8 (zero tests ran) during initial scaffold; remove once tests are added -->
    <TestingPlatformCommandLineArguments>--ignore-exit-code 8</TestingPlatformCommandLineArguments>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../../src/Domain/{{SOLUTION_NAME}}.Domain.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="TUnit" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="NSubstitute" />
  </ItemGroup>
</Project>
